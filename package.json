{
  "name": "mariaboss",
  "version": "0.1.0",
  "description": "Job queue for Node.js on MariaDB 10.6+ using FOR UPDATE SKIP LOCKED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mariaboss": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./migrations/*": "./migrations/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "node scripts/prepare.mjs",
    "prepublishOnly": "npm run lint && npx vitest run tests/unit && npm run build",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests benchmarks",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"benchmarks/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"benchmarks/**/*.ts\"",
    "benchmark": "tsx benchmarks/run-all.ts",
    "stress": "tsx tests/stress/enqueue-flood.ts",
    "migration:up": "node dist/cli.js migrate",
    "migration:down": "node dist/cli.js down",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phlucasfr/maria-boss.git"
  },
  "bugs": {
    "url": "https://github.com/phlucasfr/maria-boss/issues"
  },
  "homepage": "https://github.com/phlucasfr/maria-boss#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "queue",
    "job-queue",
    "mariadb",
    "mysql",
    "bullmq",
    "pg-boss",
    "worker",
    "distributed",
    "skip-locked",
    "background-jobs"
  ],
  "author": "phlucasfr",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "cron-parser": "^5.0.3",
    "mysql2": "^3.14.0",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tinybench": "^4.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
